PORT=3101
# Optional; when set, require Bearer token or x-cloudflare-worker-secret for /all, /diff, /federal/*, /provincial/* (same as @yc/mq).
# API_TUNNEL_SECRET=

# Root directory for JSON output. Docker image defaults to /data (mount a persistent volume there).
# DATA_DIR=./data

# When true, run scrape:all in the background after HTTP starts (useful after a fresh volume).
# SCRAPE_ON_STARTUP=true

# BC LIMS GraphQL parliament id (default 43). Bump when BC starts a new parliament.
# BC_PARLIAMENT_ID=43
