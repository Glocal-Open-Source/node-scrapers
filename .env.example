PORT=3101
# Optional; when set, require Bearer token or x-cloudflare-worker-secret for /all, /diff, /federal/*, /provincial/* (same as @yc/mq).
# API_TUNNEL_SECRET=

# Root directory for JSON output (`federal/<slug>.json`, `provincial/<slug>.json`). Default: ./data under cwd.
# DATA_DIR=./data

# BC LIMS GraphQL parliament id (default 43). Bump when BC starts a new parliament.
# BC_PARLIAMENT_ID=43
